---
import Button from '../components/Button.astro';
import { Image } from 'astro:assets';
import brianImage from '../images/brian-exequiel.png';
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
// Código SVG para los íconos
const downloadIcon = `
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
  <!-- Define el gradiente lineal de izquierda a derecha -->
  <defs>
    <linearGradient id="myGradient" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#6604fd;stop-opacity:1" /> <!-- Color inicial (#6604fd) -->
      <stop offset="50%" style="stop-color:#fd003c;stop-opacity:1" /> <!-- Color intermedio (#fd003c) -->
      <stop offset="100%" style="stop-color:#fdba01;stop-opacity:1" /> <!-- Color final (#fdba01) -->
    </linearGradient>
  </defs>
  <!-- Aplica el gradiente al path -->
  <path fill="url(#myGradient)" d="m12 16l-5-5l1.4-1.45l2.6 2.6V4h2v8.15l2.6-2.6L17 11zm-6 4q-.825 0-1.412-.587T4 18v-3h2v3h12v-3h2v3q0 .825-.587 1.413T18 20z"/>
</svg>
`;
---

<section class="hero-section">
  <div class="hero__container-left">
    <h2 class="hero__title1">{t("hero.presentation")}</h2>
    <h2 class="hero__title2">{t("hero.title")}</h2>
    <p class="hero__subtitle">{t("hero.subtitle")}</p>
    <Button variant="primary" title={t("nav.contact")}/>
    <Button variant="secondary" title="Descargar CV" iconRight={downloadIcon} download href="/public/cv/Curriculum-Brian-Putallaz.pdf" downloadName="Curriculum-Brian-Putallaz.pdf"/>
  </div>
  
  <div class="hero__container-right">
    <Image src={brianImage} alt="Brian Exequiel" format="png"/>
  </div>
</section>

<style>
  .hero-section {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    padding: 0 2rem;
    min-height: calc(100vh - 100px);
    position: relative;
    top: 6.25rem;
    gap: 2rem; /* Espacio entre contenedores */
  }

  .hero__container-left {
    flex: 1 1 50%;
    min-width: 400px;
    max-width: 600px;
  }

  .hero__container-right {
    flex: 1 1 40%;
    min-width: 300px;
    display: flex;
    justify-content: center;
  }

  .hero__container-right img {
    width: 100%;
    height: auto;
    max-width: 500px;
    object-fit: contain;
  }

  .hero__title1 {
    color: var(--color-title);
    font-weight: 700;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    margin-bottom: 1rem;
  }

  .hero__title2 {
    background-image: var(--gradient);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    font-weight: 700;
    font-size: clamp(2.2rem, 5vw, 3rem);
    line-height: 1.4;
    margin-bottom: 2rem;
  }

  .hero__subtitle {
    color: var(--color-subtitle);
    font-size: 1rem;
    max-width: 600px;
    margin-bottom: 2rem;
  }

  /* Media Queries mejoradas */
  @media (max-width: 1090px) {
    .hero-section {
      padding-top: 2rem;
      justify-content: center;
      gap: 3rem;
    }
    .hero__container-left {
      text-align: center;
    }
    .hero__container-left,
    .hero__container-right {
      flex: 1 1 100%;
      min-width: auto;
      max-width: 600px;
    }
    
    .hero__container-right img {
      max-width: 400px;
    }
  }

  @media (max-width: 768px) {
    .hero-section {
      padding: 0 2rem;
      top: 5rem;
    }
    
    
    
    .hero__title1 {
      font-size: 1.8rem;
    }
    
    .hero__title2 {
      font-size: 2.2rem;
    }
    
    .hero__subtitle {
      margin-left: auto;
      margin-right: auto;
    }
    
    .hero__container-right img {
      max-width: 350px;
    }
  }

  @media (max-width: 480px) {
    .hero__title1 {
      font-size: 1.5rem;
    }
    
    .hero__title2 {
      font-size: 1.8rem;
    }
    
    .hero__container-right img {
      max-width: 280px;
    }
  }
</style>