---
// Props del componente
export interface Props {
    variant?: "primary" | "secondary"
    title: string
    iconLeft?: string
    iconRight?: string
    class?: string
    download?: boolean
    href?: string
    downloadName?: string
    onClick?: () => void
}

const {
    variant = "primary",
    title,
    iconLeft,
    iconRight,
    class: customClass = "",
    download = false,
    href = "",
    downloadName = "",
    onClick
} = Astro.props
---

<!-- Componente Button con soporte para descargas -->
{download ? (
    <a 
        href={href}
        download={downloadName || href.split('/').pop()}
        class={`button ${variant} ${customClass}`}
        aria-label={`Descargar ${downloadName || 'archivo'}`}
    >
        {iconLeft && <span class="icon icon-left" set:html={iconLeft} />}
        {title}
        {iconRight && <span class="icon icon-right" set:html={iconRight} />}
    </a>
) : (
    <button 
        class={`button ${variant} ${customClass}`}
        onClick={onClick}
    >
        {iconLeft && <span class="icon icon-left" set:html={iconLeft} />}
        {title}
        {iconRight && <span class="icon icon-right" set:html={iconRight} />}
    </button>
)}

<style>
    /* Estilos base del botón */
    .button, a.button {
        width: 220px;
        padding: 0.75rem 1.5rem;
        border-radius: 0.5rem;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        border: none;
        position: relative;
        overflow: hidden;
        z-index: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        text-decoration: none;
    }
    
    .button:hover, a.button:hover {
        transform: scale(0.98);
    }
    
    .button:active, a.button:active {
        transform: scale(0.95);
    }

    /* Estilos para la variante primary */
    .button.primary, a.button.primary {
        background: linear-gradient(to right, #6604fd, #fd003c, #fdba01);
        color: white;
    }

    .button.primary:hover, a.button.primary:hover {
        opacity: 0.9;
    }

    /* Estilos para la variante secondary */
    .button.secondary, a.button.secondary {
        background: transparent;
        color: hsl(340, 84%, 32%);
        border: 2px solid transparent;
        position: relative;
    }

    /* Pseudoelemento para el borde de gradiente */
    .button.secondary::before, a.button.secondary::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: -1;
        border-radius: 0.5rem;
        border: 2px solid transparent;
        background: linear-gradient(to right, #6604fd, #fd003c, #fdba01)
            border-box;
        mask:
            linear-gradient(#fff 0 0) padding-box,
            linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        transition: all 0.3s ease;
    }

    /* Estilos para los íconos */
    .icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.5rem;
        height: 1.5rem;
    }

    .icon-left {
        margin-right: 0.5rem;
    }

    .icon-right {
        margin-left: 0.5rem;
    }
</style>